{
  "project": {
    "name": "toolwright",
    "language": "go",
    "version": "1.25",
    "framework": "cobra",
    "packageManager": "go-modules",
    "testRunner": "go-test",
    "linter": "golangci-lint",
    "formatter": "gofmt"
  },
  "commands": {
    "build": "go build ./...",
    "test": "go test ./... -v",
    "lint": "golangci-lint run ./...",
    "format": "gofmt -w ."
  },
  "gates": {
    "build": { "enabled": true },
    "tests": { "enabled": true },
    "security": { "enabled": true },
    "spec": { "enabled": true },
    "wiring": { "enabled": true }
  },
  "git": {
    "strategy": "github-flow",
    "baseBranch": "main",
    "branchPrefix": "feat/",
    "mergeStrategy": "squash",
    "prRequired": true,
    "commitFormat": "conventional",
    "commitTemplate": null,
    "branchPerWorkUnit": true,
    "cleanupBranch": true,
    "prTool": "gh"
  }
}
